# Enable MultiViews for automatic extension handling
Options +MultiViews -Indexes

# Block CLI migration scripts from web access (defense in depth)
<FilesMatch "^run_.*\.php$">
  Require all denied
</FilesMatch>

# Block database dumps and SQL files everywhere under web root
<FilesMatch "\.(sql|sql\.gz|dump)$">
  Require all denied
</FilesMatch>

# Block direct web access to sensitive directories
<IfModule mod_rewrite.c>
  RewriteEngine On
  # For local development (XAMPP in /swaapin subdir):
  RewriteBase /swaapin/
  # For production server (root domain):
  # RewriteBase /

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Remove www (optional)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # Explicitly handle /profile/ to avoid directory listing
  RewriteRule ^profile/?$ profile.php [L,NC,QSA]
  
  # Block sensitive directories
  RewriteRule ^includes/ - [F,L]
  RewriteRule ^seed/ - [F,L]
  RewriteRule ^database/ - [F,L]
  RewriteRule ^storage/ - [F,L]
  RewriteRule ^tools/ - [F,L]
  RewriteRule ^vendor/ - [F,L]
  RewriteRule ^logs/ - [F,L]
  RewriteRule ^backups/ - [F,L]
  RewriteRule ^sql/ - [F,L]

  # Support/index.php -> /support
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^support/?$ support/index.php [L,NC,QSA]

  # Store/index.php -> /store
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^store/?$ store/index.php [L,NC,QSA]

  # Handle trailing slashes for files (e.g., /profile/ -> /profile.php)
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME} ^(.+)/$
  RewriteCond %1.php -f
  RewriteRule ^(.+)/$ $1.php [L,QSA]

  # Remove .php extension (prioritize files over directories)
  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^([^/]+)/?$ $1.php [L,QSA]
  
  # Handle /sep/callback route for backward compatibility
  RewriteRule ^sep/callback/?$ payment_callback.php [L,NC,QSA]

  # Handle subdirectories like /auth/login
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/swaapin/$1.php -f
  RewriteRule ^(.+?)/?$ $1.php [L,QSA]
</IfModule>

# Custom error documents
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php

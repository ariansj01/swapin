# Block CLI migration scripts from web access (defense in depth)
<FilesMatch "^run_.*\.php$">
  Require all denied
</FilesMatch>

# Block database dumps if accidentally copied here
<FilesMatch "\.sql$">
  Require all denied
</FilesMatch>

# Block direct web access to PHP includes
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^includes/ - [F,L]
</IfModule>
